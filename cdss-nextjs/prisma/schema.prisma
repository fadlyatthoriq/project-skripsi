generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(NURSE)
  createdAt   DateTime     @default(now())
  predictions Prediction[]

  @@map("users")
}

model Prediction {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id])
  pregnancies             Float
  glucose                 Float
  bloodPressure           Float
  skinThickness           Float
  insulin                 Float
  bmi                     Float
  diabetesPedigreeFunction Float
  age                     Int
  result                  Int      // 0 = tidak berisiko, 1 = berisiko
  probability             Float
  riskLabel               String
  recommendation          String   @db.Text
  glucoseSummary          String
  bmiSummary              String
  bloodPressureSummary    String
  ageSummary              String
  createdAt               DateTime @default(now())

  @@map("predictions")
}

enum Role {
  NURSE
  DOCTOR
  ADMIN
  PATIENT
}
